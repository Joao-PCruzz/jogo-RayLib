{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compilar jogo",
      "type": "shell",
      "command": "gcc",
      "args": [
        "main.c",
        "player.c",
        "enemy.c",

        "-I../include",
        "-L/mingw64/lib",

        "-lraylib",
        "-lopengl32",
        "-lgdi32",
        "-lwinmm",

        "-o",
        "jogo.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}